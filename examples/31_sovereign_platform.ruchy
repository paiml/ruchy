// Ruchy 5.0: The Sovereign Platform Language
// Demonstrates 5.0 keywords and the nine-pillar architecture

// --- Pillar 1: Correctness (requires/ensures) ---
fun safe_sqrt(x: f64) -> f64 requires x >= 0.0 {
    x.sqrt()
}

